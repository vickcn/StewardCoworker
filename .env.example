# ─────────────────────────────────────────────────────────────────────────────
# StewardCoworker — Environment Variables
# Copy this file to .env.local and fill in all required values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Auth.js (next-auth v5) ────────────────────────────────────────────────────
# Required. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional. Set explicitly for self-hosted or local tunnels (e.g. ngrok).
# Auth.js auto-detects on Vercel. Leave blank for standard local dev.
AUTH_URL=


# ── Google OAuth (platform login) ────────────────────────────────────────────
# Required. Create at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: {AUTH_URL}/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional. Required only if you want in-page "瀏覽" (Google Picker) buttons.
# Create a Browser API key and Picker App ID (Cloud project number).
NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=
NEXT_PUBLIC_GOOGLE_PICKER_APP_ID=


# ── Google Service Account (legacy optional mode) ─────────────────────────────
# Optional. In OAuth-user mode (方案 2) this section is not required.
# Keep only if you still need legacy service-account based integration.
# If used, create a Service Account at Google Cloud Console, then:
#   1. Generate a JSON key
#   2. Copy the "client_email" value below
#   3. Copy the "private_key" value below (keep the \n escape sequences — do NOT
#      expand them into real newlines; the code converts them at runtime)
#   4. Share each project's Google Sheet/Drive folder with this service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=


# ── Platform database ─────────────────────────────────────────────────────────
# SQLite for local development (default: prisma/dev.db, no need to change).
# Switch to a PostgreSQL URL for production: postgresql://user:pass@host/db
DATABASE_URL=file:./prisma/dev.db


# ── Public base URL ───────────────────────────────────────────────────────────
# Used to build share links (e.g. https://yourapp.com/p/<token>).
# Must be set in production. Local default is http://localhost:3000.
NEXT_PUBLIC_BASE_URL=http://localhost:3000


# ─────────────────────────────────────────────────────────────────────────────
# NOT USED (removed — project-level integration replaced these globals):
#   SPREADSHEET_ID        → stored in ProjectIntegration.spreadsheetId
#   GOOGLE_DRIVE_FOLDER_ID → stored in ProjectIntegration.driveFolderId
#   ALLOWED_EDITOR_EMAILS  → replaced by ProjectMember role model
# ─────────────────────────────────────────────────────────────────────────────
